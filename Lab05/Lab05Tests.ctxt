#BlueJ class context
comment0.target=Lab05Tests
comment0.text=\n\ Unit\ tests\ for\ Word\ and\ WordList.\n\n\ Structure\:\n\ \ \ -\ Word\ tests\:\ constructor,\ increment,\ toString,\ compareTo.\n\ \ \ -\ WordList\ Lab\ 4\ tests\:\ construction,\ filtering,\ search,\ getMostFrequent,\n\ \ \ \ \ topKMostFrequent.\n\ \ \ -\ WordList\ Lab\ 5\ tests\:\ distinctWordsCount,\ shortWordsCount\ (including\n\ \ \ \ \ assertThrows\ for\ negative\ threshold),\ mostFrequentByLetter.\n\n\ \ +\ there\ are\ some\ explanations\ to\ some\ tests(needed\ for\ myself)\n\ @author\ Ali\ Kablanbek\n\ @version\ 3/3/26\n\ \n
comment1.params=
comment1.target=java.util.ArrayList\ basicStopWords()
comment1.text=Minimal\ stop-words\ list\ for\ tests\ that\ just\ need\ a\ few\ filtered\ words.
comment10.params=
comment10.target=void\ testCompareToLess()
comment10.text=WHY\:\ Lower-frequency\ caller\ must\ return\ a\ negative\ value.
comment11.params=
comment11.target=void\ testCompareToGreater()
comment11.text=WHY\:\ Higher-frequency\ caller\ must\ return\ a\ positive\ value.
comment12.params=
comment12.target=void\ testCompareToExactDifference()
comment12.text=WHY\:\ The\ lab\ spec\ says\ compareTo\ equals\ this.frequency\ -\ w.frequency\ exactly.
comment13.params=
comment13.target=void\ testStopWordsFiltered()
comment13.text=WHY\:\ Stop\ words\ must\ be\ silently\ excluded\ from\ wordFrequency.
comment14.params=
comment14.target=void\ testStopWordsCaseInsensitive()
comment14.text=\n\ WHY\:\ stopwords.txt\ has\ mixed-case\ entries\ like\ "But",\ so\ isStopWord()\n\ must\ use\ equalsIgnoreCase()\ to\ catch\ them\ after\ toLowerCase().\n
comment15.params=
comment15.target=void\ testFrequencyCounting()
comment15.text=WHY\:\ Each\ unique\ non-stop\ token\ must\ accumulate\ the\ correct\ count.
comment16.params=
comment16.target=void\ testAllStopWords()
comment16.text=WHY\:\ All\ stop-words\ input\ must\ produce\ an\ empty\ (not\ null)\ list.
comment17.params=
comment17.target=void\ testEmptyTokenArray()
comment17.text=WHY\:\ Empty\ token\ array\ must\ produce\ an\ empty\ list\ without\ throwing.
comment18.params=
comment18.target=void\ testGetWordFrequency()
comment18.text=WHY\:\ getWordFrequency()\ must\ return\ a\ non-null\ list\ of\ the\ correct\ size.
comment19.params=
comment19.target=void\ testSearchNotFound()
comment19.text=WHY\:\ search()\ must\ return\ -1\ for\ an\ absent\ word.
comment2.params=words\ counts
comment2.target=java.lang.String[]\ buildTokenArray(java.lang.String[],\ int[])
comment2.text=Builds\ a\ flat\ token\ array\ from\ parallel\ word/count\ arrays.
comment20.params=
comment20.target=void\ testSearchReturnsCorrectIndex()
comment20.text=WHY\:\ The\ returned\ index\ must\ point\ to\ the\ correct\ Word,\ not\ just\ be\ >\=\ 0.
comment21.params=
comment21.target=void\ testGetMostFrequent()
comment21.text=WHY\:\ getMostFrequent()\ must\ identify\ the\ word\ with\ the\ highest\ count.
comment22.params=
comment22.target=void\ testGetMostFrequentEmptyList()
comment22.text=WHY\:\ getMostFrequent()\ must\ return\ null\ for\ an\ empty\ list,\ not\ throw.
comment23.params=
comment23.target=void\ testGetMostFrequentAllTied()
comment23.text=WHY\:\ In\ a\ tie,\ getMostFrequent()\ must\ still\ return\ a\ valid\ Word.
comment24.params=
comment24.target=void\ testTopKMostFrequent()
comment24.text=WHY\:\ Verifies\ correct\ descending\ order\ and\ array\ length.
comment25.params=
comment25.target=void\ testTopKExceedsListSize()
comment25.text=WHY\:\ k\ >\ list\ size\ must\ cap\ at\ list\ size\ with\ no\ null\ entries.
comment26.params=
comment26.target=void\ testTopOneMostFrequent()
comment26.text=WHY\:\ topKMostFrequent(1)\ and\ getMostFrequent()\ must\ agree.
comment27.params=
comment27.target=void\ testDistinctWordsCountNormal()
comment27.text=WHY\:\ Repeated\ tokens\ must\ be\ collapsed;\ 5\ raw\ tokens\ \u2192\ 3\ distinct\ strings.
comment28.params=
comment28.target=void\ testDistinctWordsCountAllSame()
comment28.text=WHYYYY\:\ All\ identical\ tokens\ must\ return\ 1,\ not\ the\ raw\ count.
comment29.params=
comment29.target=void\ testDistinctWordsCountIgnoresEmptyStrings()
comment29.text=\n\ WHY?\:\ split()\ can\ produce\ empty\ strings\ at\ array\ boundaries;\ they\ must\n\ not\ be\ counted\ as\ distinct\ words.\n
comment3.params=
comment3.target=void\ testWordConstructorAndGetters()
comment3.text=WHY\:\ Confirms\ the\ constructor\ stores\ the\ word\ and\ starts\ frequency\ at\ 1.
comment30.params=
comment30.target=void\ testDistinctWordsCountEmptyArray()
comment30.text=WHY\:\ Empty\ array\ must\ return\ 0\ without\ throwing.
comment31.params=
comment31.target=void\ testShortWordsCountNormal()
comment31.text=\n\ WHY\:\ With\ threshold\ 3,\ "cat"(3)\ and\ "ox"(2)\ qualify;\ "lion"(4)\ does\ not.\n\ Verifies\ the\ filter\ is\ <\=\ (inclusive),\ not\ <.\n
comment32.params=
comment32.target=void\ testShortWordsCountThresholdZero()
comment32.text=WHY\:\ Threshold\ 0\ means\ no\ word\ can\ qualify\ (every\ string\ has\ length\ >\=\ 1).
comment33.params=
comment33.target=void\ testShortWordsCountThresholdCoversAll()
comment33.text=WHY\:\ Threshold\ >\=\ longest\ word\ means\ every\ word\ qualifies.
comment34.params=
comment34.target=void\ testShortWordsCountNegativeThrows()
comment34.text=\n\ WHY\:\ A\ negative\ threshold\ has\ no\ meaningful\ definition\ and\ must\ throw\n\ IllegalArgumentException.\ \ The\ lambda\ ()\ ->\ ...\ is\ the\ code\ under\ test;\n\ assertThrows\ catches\ the\ exception\ and\ fails\ the\ test\ if\ none\ is\ thrown.\n
comment35.params=
comment35.target=void\ testShortWordsCountNegativeThrowsMessage()
comment35.text=\n\ WHY\:\ assertThrows\ returns\ the\ caught\ exception\ so\ we\ can\ inspect\ its\n\ message\ and\ confirm\ the\ right\ code\ path\ was\ hit.\n
comment36.params=
comment36.target=void\ testMostFrequentByLetterNormal()
comment36.text=\n\ WhY\:\ "python"(4)\ beats\ "prime"(2)\ among\ 'p'-words;\ "castle"(3)\ is\n\ excluded\ by\ the\ filter\ even\ though\ it\ has\ higher\ frequency\ than\ "prime".\n
comment37.params=
comment37.target=void\ testMostFrequentByLetterNoMatch()
comment37.text=\n\ WHY\:\ No\ matching\ letter\ means\ the\ filtered\ stream\ is\ empty;\n\ orElse(null)\ must\ return\ null\ rather\ than\ throw.\n
comment38.params=
comment38.target=void\ testMostFrequentByLetterSingleMatch()
comment38.text=WHY\:\ max()\ on\ a\ single-element\ stream\ must\ return\ that\ element.
comment39.params=
comment39.target=void\ testMostFrequentByLetterCaseSensitive()
comment39.text=\n\ WHY\:\ Tokens\ are\ lowercased\ in\ main,\ so\ uppercase\ 'P'\ should\ find\ nothing\n\ in\ a\ properly\ built\ WordList.\ \ Confirms\ the\ method\ is\ case-sensitive.\n
comment4.params=
comment4.target=void\ testIncrementOnce()
comment4.text=WHY\:\ One\ increment\ is\ the\ most\ common\ case;\ counter\ must\ go\ from\ 1\ to\ 2.
comment5.params=
comment5.target=void\ testIncrementMultipleTimes()
comment5.text=WHY\:\ Multiple\ increments\ must\ accumulate,\ not\ reset\ or\ cap.
comment6.params=
comment6.target=void\ testToStringFormat()
comment6.text=WHY\:\ The\ lab\ specifies\ the\ exact\ format\ <word,\ frequency>.
comment7.params=
comment7.target=void\ testToStringAfterIncrement()
comment7.text=WHY\:\ toString()\ must\ reflect\ the\ current\ (live)\ frequency,\ not\ a\ snapshot.
comment8.params=
comment8.target=void\ testCompareToSelf()
comment8.text=WHY\:\ The\ lab\ demos\ self-comparison\ returning\ 0\ (n\ -\ n\ \=\=\ 0).
comment9.params=
comment9.target=void\ testCompareToEqualFrequency()
comment9.text=WHY\:\ Two\ objects\ with\ equal\ frequency\ must\ return\ 0.
